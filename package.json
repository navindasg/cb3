{
  "name": "candy-box-3",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "GPL-3.0-or-later",
  "description": "Candy Box 3 — an honorary sequel to aniwey's Candy Box (2013) and Candy Box 2 (2013). Browser-based ASCII incremental-RPG.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
